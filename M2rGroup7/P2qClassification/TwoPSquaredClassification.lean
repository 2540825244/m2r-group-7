/-- Canonical nontrivial action `C_2 вҶ’* Aut(C_{p^2})`, image of order 2. -/
def canonicalC2OnCp2Action {p : в„•} [h_p_prime : Fact p.Prime] (h_p_ne_2 : p вү  2) :
    CyclicGroup 2 вҶ’* MulAut (CyclicGroup (p ^ 2)) :=
  haveI := h_p_prime
  haveI : Fact (Nat.Prime 2) := вҹЁby norm_numвҹ©
  haveI : NeZero (p ^ 2) := вҹЁpow_ne_zero 2 h_p_prime.out.ne_zeroвҹ©
  haveI : NeZero (2 : в„•) := вҹЁby norm_numвҹ©
  haveI : NeZero ((2:в„•) ^ 1) := вҹЁpow_ne_zero 1 (by norm_num)вҹ©
  transportCpCqHom (pow_one 2) (rfl : p ^ 2 = p ^ 2)
    (canonicalAction 2 p 2 1 (Ne.symm h_p_ne_2) h_p_ne_2 (by norm_num)
       1 (by
          have h := (Nat.le_min.mp (one_le_min_two_factorization_two h_p_ne_2)).2
          exact Nat.le_min.mpr вҹЁle_refl 1, hвҹ©))

/-! ## Canonical actions on `C_p Г— C_p` for the `C_2` factor.

We build two elementary automorphisms of `C_p Г— C_p`: inversion on the second
coordinate (`cpcpInvSecond`) and inversion on both coordinates (`cpcpInvBoth`).
Both have order dividing 2; we turn them into actions `C_2 вҶ’* MulAut (C_p Г— C_p)`
via `cyclicHom`. -/

/-- Inversion on the second coordinate of `C_p Г— C_p`. -/
def cpcpInvSecond (p : в„•) [NeZero p] : MulAut (CyclicGroup p Г— CyclicGroup p) where
  toFun x := (x.1, x.2вҒ»В№)
  invFun x := (x.1, x.2вҒ»В№)
  left_inv := by rintro вҹЁa, bвҹ©; simp
  right_inv := by rintro вҹЁa, bвҹ©; simp
  map_mul' := by
    rintro вҹЁaвӮҒ, bвӮҒвҹ© вҹЁaвӮӮ, bвӮӮвҹ©
    refine Prod.ext rfl ?_
    change (bвӮҒ * bвӮӮ)вҒ»В№ = bвӮҒвҒ»В№ * bвӮӮвҒ»В№
    rw [mul_inv]

/-- Inversion on both coordinates of `C_p Г— C_p`. -/
def cpcpInvBoth (p : в„•) [NeZero p] : MulAut (CyclicGroup p Г— CyclicGroup p) where
  toFun x := (x.1вҒ»В№, x.2вҒ»В№)
  invFun x := (x.1вҒ»В№, x.2вҒ»В№)
  left_inv := by rintro вҹЁa, bвҹ©; simp
  right_inv := by rintro вҹЁa, bвҹ©; simp
  map_mul' := by
    rintro вҹЁaвӮҒ, bвӮҒвҹ© вҹЁaвӮӮ, bвӮӮвҹ©
    refine Prod.ext ?_ ?_
    В· change (aвӮҒ * aвӮӮ)вҒ»В№ = aвӮҒвҒ»В№ * aвӮӮвҒ»В№; rw [mul_inv]
    В· change (bвӮҒ * bвӮӮ)вҒ»В№ = bвӮҒвҒ»В№ * bвӮӮвҒ»В№; rw [mul_inv]

lemma cpcpInvSecond_sq (p : в„•) [NeZero p] : (cpcpInvSecond p) ^ 2 = 1 := by
  ext x
  В· rw [sq, MulAut.mul_apply, MulAut.one_apply]
    change ((x.1, x.2вҒ»В№).1, (x.1, x.2вҒ»В№).2вҒ»В№).1 = x.1
    simp
  В· rw [sq, MulAut.mul_apply, MulAut.one_apply]
    change ((x.1, x.2вҒ»В№).1, (x.1, x.2вҒ»В№).2вҒ»В№).2 = x.2
    simp

lemma cpcpInvBoth_sq (p : в„•) [NeZero p] : (cpcpInvBoth p) ^ 2 = 1 := by
  ext x
  В· rw [sq, MulAut.mul_apply, MulAut.one_apply]
    change ((x.1вҒ»В№, x.2вҒ»В№).1вҒ»В№, (x.1вҒ»В№, x.2вҒ»В№).2вҒ»В№).1 = x.1
    simp
  В· rw [sq, MulAut.mul_apply, MulAut.one_apply]
    change ((x.1вҒ»В№, x.2вҒ»В№).1вҒ»В№, (x.1вҒ»В№, x.2вҒ»В№).2вҒ»В№).2 = x.2
    simp

/-- Canonical action `C_2 вҶ’* Aut(C_p Г— C_p)` with image generated by inversion on the
second coordinate. -/
def canonicalC2OnCpCpAction_r1 (p : в„•) [NeZero p] :
    CyclicGroup 2 вҶ’* MulAut (CyclicGroup p Г— CyclicGroup p) :=
  cyclicHom 2 (cpcpInvSecond p) (cpcpInvSecond_sq p)

/-- Canonical action `C_2 вҶ’* Aut(C_p Г— C_p)` with image generated by inversion on both
coordinates (the "minus identity" action). -/
def canonicalC2OnCpCpAction_r2 (p : в„•) [NeZero p] :
    CyclicGroup 2 вҶ’* MulAut (CyclicGroup p Г— CyclicGroup p) :=
  cyclicHom 2 (cpcpInvBoth p) (cpcpInvBoth_sq p)

/-! ## Conjugacy classification of order-two elements of `MulAut(C_p Г— C_p)`.

For `p` an odd prime, every order-two element of `MulAut(C_p Г— C_p)` is conjugate
in `MulAut(C_p Г— C_p)` to either `cpcpInvSecond p` or `cpcpInvBoth p`. -/

/-- For an odd prime `p`, every order-two element `Пғ` of `MulAut(C_p Г— C_p)` is
conjugate to one of the two canonical inversion automorphisms `cpcpInvSecond p` or
`cpcpInvBoth p`.

The proof strategy is to view `Additive (C_p Г— C_p)` as a 2-dimensional `F_p`-vector
space and analyse the Вұ1 eigenspaces of the linear automorphism corresponding to `Пғ`.
Either both `+1` and `-1` eigenspaces are 1-dimensional (giving the `cpcpInvSecond`
case via a change-of-basis), or `Пғ` acts as `-id` (giving the `cpcpInvBoth` case
directly). -/
lemma mulAut_cpcp_order_two_conj {p : в„•} [hp : Fact p.Prime] (hp_ne_2 : p вү  2)
    (Пғ : MulAut (CyclicGroup p Г— CyclicGroup p)) (hПғ : orderOf Пғ = 2) :
    IsConj (cpcpInvSecond p) Пғ вҲЁ IsConj (cpcpInvBoth p) Пғ := by
  set H := CyclicGroup p Г— CyclicGroup p with hH_def
  haveI : NeZero p := вҹЁhp.out.pos.ne'вҹ©
  -- ПғВІ = 1, Пғ вү  1
  have hПғ_sq : Пғ ^ 2 = 1 := by
    have h := pow_orderOf_eq_one Пғ; rw [hПғ] at h; exact h
  have hПғ_ne_one : Пғ вү  1 := by
    intro h; rw [h, orderOf_one] at hПғ; exact absurd hПғ (by norm_num)
  -- Пғ вҲҳ Пғ = id pointwise
  have hПғПғ : вҲҖ x : H, Пғ (Пғ x) = x := by
    intro x
    have h : (Пғ * Пғ) x = (1 : MulAut H) x := by
      rw [show Пғ * Пғ = Пғ ^ 2 from (sq Пғ).symm, hПғ_sq]
    rwa [MulAut.mul_apply, MulAut.one_apply] at h
  -- p-power triviality
  have h_pow_p : вҲҖ h : H, h ^ p = 1 := by
    intro h
    obtain вҹЁa, bвҹ© := h
    have h_card_cp : Nat.card (CyclicGroup p) = p := card_cyclicGroup p
    have h_one : вҲҖ z : CyclicGroup p, z ^ p = 1 := fun z => by
      have h := pow_card_eq_one' (G := CyclicGroup p) (x := z)
      rwa [h_card_cp] at h
    change (a ^ p, b ^ p) = (1, 1)
    rw [h_one a, h_one b]
  -- Additive structure
  have h_nsmul_p : вҲҖ x : Additive H, (p : в„•) вҖў x = 0 := by
    intro x
    have : Additive.ofMul (Additive.toMul x ^ p) = (p : в„•) вҖў x := ofMul_pow p (Additive.toMul x)
    rw [вҶҗ this]
    change Additive.ofMul _ = Additive.ofMul 1
    rw [h_pow_p]
  haveI inst_mod : Module (ZMod p) (Additive H) := AddCommGroup.zmodModule h_nsmul_p
  haveI : Fintype H := instFintypeProd _ _
  haveI : Fintype (ZMod p) := ZMod.fintype p
  haveI : Fintype (Additive H) := Additive.fintype
  have h_card_addH : Nat.card (Additive H) = p ^ 2 := by
    rw [show Nat.card (Additive H) = Nat.card H from Nat.card_congr Additive.toMul]
    change Nat.card (CyclicGroup p Г— CyclicGroup p) = p ^ 2
    rw [Nat.card_prod, card_cyclicGroup]; ring
  have h_card_zmod : Nat.card (ZMod p) = p := by
    rw [Nat.card_eq_fintype_card, ZMod.card]
  have h_finrank_addH : Module.finrank (ZMod p) (Additive H) = 2 := by
    have h := Module.card_eq_pow_finrank (K := ZMod p) (V := Additive H)
    rw [вҶҗ Nat.card_eq_fintype_card, вҶҗ Nat.card_eq_fintype_card,
        h_card_addH, h_card_zmod] at h
    have hp2 : 2 вүӨ p := hp.out.two_le
    exact (Nat.pow_right_injective hp2 h).symm
  -- Case A: Пғ = cpcpInvBoth p
  by_cases h_eq_both : Пғ = cpcpInvBoth p
  В· right
    rw [вҶҗ h_eq_both]
  -- Case B: Пғ вү  cpcpInvBoth p
  В· left
    -- Step 1: find z with Пғ z вү  zвҒ»В№ (otherwise Пғ = cpcpInvBoth p)
    have h_exists_z : вҲғ z : H, Пғ z вү  zвҒ»В№ := by
      by_contra h_all
      push_neg at h_all
      apply h_eq_both
      ext x
      В· show (Пғ x).1 = (cpcpInvBoth p x).1
        have h := h_all x
        change (Пғ x).1 = x.1вҒ»В№
        have h_inv : Пғ x = xвҒ»В№ := h
        rw [h_inv]
        rfl
      В· show (Пғ x).2 = (cpcpInvBoth p x).2
        have h := h_all x
        change (Пғ x).2 = x.2вҒ»В№
        have h_inv : Пғ x = xвҒ»В№ := h
        rw [h_inv]
        rfl
    obtain вҹЁz, hzвҹ© := h_exists_z
    -- u := z * Пғ z is a +1 eigenvector
    set u : H := z * Пғ z with hu_def
    have hu_ne : u вү  1 := by
      intro h
      apply hz
      have h_eq : z * Пғ z = 1 := h
      exact mul_eq_one_iff_eq_inv'.mp h_eq
    have hu_fixed : Пғ u = u := by
      show Пғ (z * Пғ z) = z * Пғ z
      rw [map_mul, hПғПғ z]
      rw [mul_comm]
    -- Step 2: find w with Пғ w вү  w (otherwise Пғ = 1)
    have h_exists_w : вҲғ w : H, Пғ w вү  w := by
      by_contra h_all
      push_neg at h_all
      apply hПғ_ne_one
      ext x
      В· show (Пғ x).1 = ((1 : MulAut H) x).1
        rw [h_all x]; rfl
      В· show (Пғ x).2 = ((1 : MulAut H) x).2
        rw [h_all x]; rfl
    obtain вҹЁw, hwвҹ© := h_exists_w
    -- v := w * (Пғ w)вҒ»В№ is a -1 eigenvector
    set v : H := w * (Пғ w)вҒ»В№ with hv_def
    have hv_ne : v вү  1 := by
      intro h
      apply hw
      have h_eq : w * (Пғ w)вҒ»В№ = 1 := h
      have := mul_inv_eq_one.mp h_eq
      exact this.symm
    have hv_inv : Пғ v = vвҒ»В№ := by
      show Пғ (w * (Пғ w)вҒ»В№) = (w * (Пғ w)вҒ»В№)вҒ»В№
      rw [map_mul, map_inv, hПғПғ w, mul_inv_rev, inv_inv, mul_comm]
    -- Step 3: u_add, v_add are linearly independent eigenvectors
    set u_add : Additive H := Additive.ofMul u with hu_add_def
    set v_add : Additive H := Additive.ofMul v with hv_add_def
    have hu_add_ne : u_add вү  0 := by
      intro h
      apply hu_ne
      change Additive.toMul u_add = Additive.toMul (0 : Additive H)
      rw [h]
    have hv_add_ne : v_add вү  0 := by
      intro h
      apply hv_ne
      change Additive.toMul v_add = Additive.toMul (0 : Additive H)
      rw [h]
    -- Build ПҲ from Пғ via AddAutAdditive.symm
    let ПҲ : Additive H вүғ+ Additive H := (AddAutAdditive (G := H)).symm Пғ
    -- ПҲ u_add = u_add (eigenvalue 1)
    have h_ПҲ_u : ПҲ u_add = u_add := by
      show Additive.ofMul (Пғ u) = Additive.ofMul u
      rw [hu_fixed]
    -- ПҲ v_add = -v_add (eigenvalue -1)
    have h_ПҲ_v : ПҲ v_add = -v_add := by
      show Additive.ofMul (Пғ v) = -Additive.ofMul v
      rw [hv_inv]
      rfl
    -- ПҲ is ZMod p-linear
    have h_ПҲ_smul : вҲҖ (r : ZMod p) (x : Additive H), ПҲ (r вҖў x) = r вҖў ПҲ x := by
      intro r x
      exact (AddMonoidHom.toZModLinearMap p ПҲ.toAddMonoidHom).map_smul r x
    -- Linear independence of {u_add, v_add}: a * u_add + b * v_add = 0 вҮ’ a = b = 0
    have h_lin_indep :
        вҲҖ (a b : ZMod p), a вҖў u_add + b вҖў v_add = 0 вҶ’ a = 0 вҲ§ b = 0 := by
      intro a b h_lc
      -- Apply ПҲ to both sides: a вҖў u_add - b вҖў v_add = 0
      have h_ПҲ_lc : ПҲ (a вҖў u_add + b вҖў v_add) = 0 := by rw [h_lc, map_zero]
      rw [map_add, h_ПҲ_smul, h_ПҲ_smul, h_ПҲ_u, h_ПҲ_v, smul_neg] at h_ПҲ_lc
      -- h_ПҲ_lc : a вҖў u_add + -(b вҖў v_add) = 0
      -- Combined with original: add them to get 2a вҖў u_add = 0
      have h_sum : (2 * a) вҖў u_add = 0 := by
        have h_add : (a вҖў u_add + b вҖў v_add) + (a вҖў u_add + -(b вҖў v_add)) = 0 := by
          rw [h_lc, h_ПҲ_lc, add_zero]
        have : (a вҖў u_add + b вҖў v_add) + (a вҖў u_add + -(b вҖў v_add)) =
            (a + a) вҖў u_add := by
          rw [show a вҖў u_add + b вҖў v_add + (a вҖў u_add + -(b вҖў v_add)) =
            (a вҖў u_add + a вҖў u_add) + (b вҖў v_add + -(b вҖў v_add)) by abel,
            add_neg_cancel, add_zero, вҶҗ add_smul]
        rw [this] at h_add
        rw [show (2 * a) = a + a by ring]
        exact h_add
      -- subtract: 2b вҖў v_add = 0
      have h_sub : (2 * b) вҖў v_add = 0 := by
        have h_sub_eq : (a вҖў u_add + b вҖў v_add) - (a вҖў u_add + -(b вҖў v_add)) = 0 := by
          rw [h_lc, h_ПҲ_lc, sub_zero]
        have : (a вҖў u_add + b вҖў v_add) - (a вҖў u_add + -(b вҖў v_add)) =
            (b + b) вҖў v_add := by
          rw [show a вҖў u_add + b вҖў v_add - (a вҖў u_add + -(b вҖў v_add)) =
            (a вҖў u_add - a вҖў u_add) + (b вҖў v_add - -(b вҖў v_add)) by abel,
            sub_self, zero_add, sub_neg_eq_add, вҶҗ add_smul]
        rw [this] at h_sub_eq
        rw [show (2 * b) = b + b by ring]
        exact h_sub_eq
      -- 2 is invertible in ZMod p (since p вү  2)
      have h2_ne_zero : (2 : ZMod p) вү  0 := by
        intro h2
        have hcast : ((2 : в„•) : ZMod p) = 0 := by exact_mod_cast h2
        have h_dvd : p вҲЈ 2 := (ZMod.natCast_eq_zero_iff 2 p).mp hcast
        have h_p_eq : p = 2 :=
          (Nat.prime_dvd_prime_iff_eq hp.out Nat.prime_two).mp h_dvd
        exact hp_ne_2 h_p_eq
      have ha : a = 0 := by
        have h2a : (2 * a) = 0 := by
          by_contra h2a_ne
          -- if 2a вү  0 then 2a вҖў u_add = 0 вҮ’ u_add = 0 (since (ZMod p) is a field)
          have : u_add = 0 := by
            have h_inv : (2 * a)вҒ»В№ * (2 * a) = 1 := inv_mul_cancelвӮҖ h2a_ne
            calc u_add = ((2 * a)вҒ»В№ * (2 * a)) вҖў u_add := by rw [h_inv, one_smul]
              _ = (2 * a)вҒ»В№ вҖў ((2 * a) вҖў u_add) := by rw [mul_smul]
              _ = (2 * a)вҒ»В№ вҖў (0 : Additive H) := by rw [h_sum]
              _ = 0 := smul_zero _
          exact hu_add_ne this
        rcases mul_eq_zero.mp h2a with h | h
        В· exact absurd h h2_ne_zero
        В· exact h
      have hb : b = 0 := by
        have h2b : (2 * b) = 0 := by
          by_contra h2b_ne
          have : v_add = 0 := by
            have h_inv : (2 * b)вҒ»В№ * (2 * b) = 1 := inv_mul_cancelвӮҖ h2b_ne
            calc v_add = ((2 * b)вҒ»В№ * (2 * b)) вҖў v_add := by rw [h_inv, one_smul]
              _ = (2 * b)вҒ»В№ вҖў ((2 * b) вҖў v_add) := by rw [mul_smul]
              _ = (2 * b)вҒ»В№ вҖў (0 : Additive H) := by rw [h_sub]
              _ = 0 := smul_zero _
          exact hv_add_ne this
        rcases mul_eq_zero.mp h2b with h | h
        В· exact absurd h h2_ne_zero
        В· exact h
      exact вҹЁha, hbвҹ©
    -- Step 4: Build the basis. First, prove u and v generate H.
    -- We'll show via linear algebra that they span Additive H, hence generate H multiplicatively.
    let b_std : Module.Basis (Fin 2) (ZMod p) (Fin 2 вҶ’ ZMod p) := Pi.basisFun (ZMod p) (Fin 2)
    let ПҶ_map : (Fin 2 вҶ’ ZMod p) вҶ’вӮ—[ZMod p] Additive H :=
      b_std.constr (ZMod p) ![u_add, v_add]
    -- ПҶ_map is injective (kernel is 0)
    have h_ПҶ_map_eвӮҖ : ПҶ_map (b_std 0) = u_add := by
      change b_std.constr (ZMod p) ![u_add, v_add] (b_std 0) = _
      rw [Module.Basis.constr_basis]; rfl
    have h_ПҶ_map_eвӮҒ : ПҶ_map (b_std 1) = v_add := by
      change b_std.constr (ZMod p) ![u_add, v_add] (b_std 1) = _
      rw [Module.Basis.constr_basis]; rfl
    have h_eвӮҖ : (b_std 0 : Fin 2 вҶ’ ZMod p) = ![1, 0] := by
      ext i; fin_cases i <;> simp [b_std, Pi.basisFun_apply, Pi.single]
    have h_eвӮҒ : (b_std 1 : Fin 2 вҶ’ ZMod p) = ![0, 1] := by
      ext i; fin_cases i <;> simp [b_std, Pi.basisFun_apply, Pi.single]
    -- ПҶ_map applied to general vector
    have h_ПҶ_map_apply : вҲҖ (a b : ZMod p),
        ПҶ_map (![a, b] : Fin 2 вҶ’ ZMod p) = a вҖў u_add + b вҖў v_add := by
      intro a b
      have h_decomp :
          (![a, b] : Fin 2 вҶ’ ZMod p) =
          a вҖў (b_std 0 : Fin 2 вҶ’ ZMod p) + b вҖў (b_std 1 : Fin 2 вҶ’ ZMod p) := by
        ext i; fin_cases i <;> simp [b_std, Pi.basisFun_apply, Pi.single]
      rw [h_decomp, map_add, LinearMap.map_smul, LinearMap.map_smul,
          h_ПҶ_map_eвӮҖ, h_ПҶ_map_eвӮҒ]
    have h_inj : Function.Injective ПҶ_map := by
      rw [вҶҗ LinearMap.ker_eq_bot]
      rw [eq_bot_iff]
      intro v hv
      rw [LinearMap.mem_ker] at hv
      -- v : Fin 2 вҶ’ ZMod p ; ПҶ_map v = 0
      have hv_eq : v = ![v 0, v 1] := by
        ext i; fin_cases i <;> rfl
      rw [hv_eq, h_ПҶ_map_apply] at hv
      obtain вҹЁh0, h1вҹ© := h_lin_indep _ _ hv
      rw [Submodule.mem_bot]
      ext i; fin_cases i
      В· exact h0
      В· exact h1
    have h_finrank_pi : Module.finrank (ZMod p) (Fin 2 вҶ’ ZMod p) = 2 := by
      rw [Module.finrank_pi]; rfl
    have h_finrank_eq : Module.finrank (ZMod p) (Fin 2 вҶ’ ZMod p) =
        Module.finrank (ZMod p) (Additive H) := by
      rw [h_finrank_pi, h_finrank_addH]
    haveI h_findim_pi : FiniteDimensional (ZMod p) (Fin 2 вҶ’ ZMod p) := inferInstance
    haveI h_findim_addH : FiniteDimensional (ZMod p) (Additive H) :=
      Module.finite_of_finrank_eq_succ h_finrank_addH
    have h_surj : Function.Surjective ПҶ_map :=
      (LinearMap.injective_iff_surjective_of_finrank_eq_finrank h_finrank_eq).mp h_inj
    -- Build the linear equiv ПҶ : (Fin 2 вҶ’ ZMod p) вүғвӮ—[ZMod p] Additive H
    let ПҶ : (Fin 2 вҶ’ ZMod p) вүғвӮ—[ZMod p] Additive H :=
      LinearEquiv.ofBijective ПҶ_map вҹЁh_inj, h_surjвҹ©
    -- u, v generate H multiplicatively
    have h_gen_uv : Subgroup.zpowers u вҠ” Subgroup.zpowers v = вҠӨ := by
      rw [eq_top_iff]
      intro h _
      -- write Additive.ofMul h = a вҖў u_add + b вҖў v_add via surjectivity of ПҶ_map
      obtain вҹЁvec, hvecвҹ© := h_surj (Additive.ofMul h)
      have hvec_eq : vec = ![vec 0, vec 1] := by ext i; fin_cases i <;> rfl
      have h_decomp : Additive.ofMul h = vec 0 вҖў u_add + vec 1 вҖў v_add := by
        calc Additive.ofMul h = ПҶ_map vec := hvec.symm
          _ = ПҶ_map ![vec 0, vec 1] := by rw [hvec_eq]
          _ = vec 0 вҖў u_add + vec 1 вҖў v_add := h_ПҶ_map_apply (vec 0) (vec 1)
      -- Convert (r : ZMod p) вҖў x to (r.val : в„Ө) вҖў x for both terms
      have h_smul_u : (vec 0) вҖў u_add = ((vec 0).val : в„Ө) вҖў u_add := by
        rw [вҶҗ Int.cast_smul_eq_zsmul (ZMod p), Int.cast_natCast, ZMod.natCast_zmod_val]
      have h_smul_v : (vec 1) вҖў v_add = ((vec 1).val : в„Ө) вҖў v_add := by
        rw [вҶҗ Int.cast_smul_eq_zsmul (ZMod p), Int.cast_natCast, ZMod.natCast_zmod_val]
      -- Now convert to multiplicative form
      have h_mul : h = u ^ ((vec 0).val : в„Ө) * v ^ ((vec 1).val : в„Ө) := by
        apply Additive.ofMul.injective
        rw [h_decomp, h_smul_u, h_smul_v, ofMul_mul, вҶҗ ofMul_zpow, вҶҗ ofMul_zpow]
      rw [h_mul]
      exact mul_mem
        (Subgroup.mem_sup_left (Subgroup.zpow_mem _ (Subgroup.mem_zpowers u) _))
        (Subgroup.mem_sup_right (Subgroup.zpow_mem _ (Subgroup.mem_zpowers v) _))
    -- Step 5: build ОІ : MulAut H from ПҶ
    let ОІ_lin : Additive H вүғвӮ—[ZMod p] Additive H := by
      -- We want ОІ maps the basis elements (1,0), (0,1) of Additive H to u_add, v_add
      -- but ОІ : Additive H вүғ Additive H. We use ПҶ to build ОІ.
      -- Actually, ОІ should send (Multiplicative.ofAdd 1, 1) to u and (1, Multiplicative.ofAdd 1) to v
      -- We use Additive H вүғвӮ— Fin 2 вҶ’ ZMod p built differently...
      -- Let's use ПҶ : (Fin 2 вҶ’ ZMod p) вүғвӮ— Additive H. We also need
      -- another equiv ПҲ_std : (Fin 2 вҶ’ ZMod p) вүғвӮ— Additive H mapping (1,0) вҶҰ (eвӮҒ, 0), (0,1) вҶҰ (0, eвӮӮ)
      -- where eвӮҒ, eвӮӮ are the standard generators.
      -- For simplicity, just build ПҶ_lin (as defined above).
      exact ПҶ.symm.trans ПҶ
    -- We don't actually use ОІ_lin this way. Let's reconstruct: we want
    -- ОІ : MulAut H with ОІ gвӮҒ = u, ОІ gвӮӮ = v where
    -- gвӮҒ := (Multiplicative.ofAdd 1, 1), gвӮӮ := (1, Multiplicative.ofAdd 1)
    -- Define standard equiv std_ПҶ : (Fin 2 вҶ’ ZMod p) вүғвӮ— Additive H by (1,0) вҶҰ Additive.ofMul gвӮҒ,
    -- (0,1) вҶҰ Additive.ofMul gвӮӮ
    set gвӮҒ : H := (Multiplicative.ofAdd (1 : ZMod p), 1) with hgвӮҒ_def
    set gвӮӮ : H := (1, Multiplicative.ofAdd (1 : ZMod p)) with hgвӮӮ_def
    let gвӮҒ_add : Additive H := Additive.ofMul gвӮҒ
    let gвӮӮ_add : Additive H := Additive.ofMul gвӮӮ
    -- Check that gвӮҒ, gвӮӮ generate H
    have h_gen_g : Subgroup.zpowers gвӮҒ вҠ” Subgroup.zpowers gвӮӮ = вҠӨ := by
      rw [eq_top_iff]
      rintro вҹЁa, bвҹ© _
      -- Express (a, b) as gвӮҒ^? * gвӮӮ^?. With g = Multiplicative.ofAdd (1 : ZMod p)
      -- being a generator of CyclicGroup p, we have a = g^i, b = g^j, so
      -- (a, b) = (g^i, 1) * (1, g^j) = gвӮҒ^i * gвӮӮ^j
      have h_card_cp : Nat.card (CyclicGroup p) = p := card_cyclicGroup p
      obtain вҹЁgcp, hgcpвҹ© := IsCyclic.exists_generator (Оұ := CyclicGroup p)
      have hgcp_order : orderOf gcp = p := by
        rw [orderOf_eq_card_of_forall_mem_zpowers hgcp, h_card_cp]
      -- Establish that Multiplicative.ofAdd 1 generates CyclicGroup p
      have h_ofAdd_gen : вҲҖ x : CyclicGroup p, x вҲҲ Subgroup.zpowers
          (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) := by
        intro x
        refine Subgroup.mem_zpowers_iff.mpr
          вҹЁ((Multiplicative.toAdd x).val : в„Ө), ?_вҹ©
        show Multiplicative.ofAdd (1 : ZMod p) ^ ((Multiplicative.toAdd x).val : в„Ө) = x
        rw [вҶҗ Multiplicative.ofAdd.apply_symm_apply x]
        show Multiplicative.ofAdd (1 : ZMod p) ^ ((Multiplicative.toAdd x).val : в„Ө)
            = Multiplicative.ofAdd (Multiplicative.toAdd x)
        rw [вҶҗ ofAdd_zsmul, zsmul_one]
        congr 1
        push_cast
        exact ZMod.natCast_zmod_val _
      obtain вҹЁi, hiвҹ© := Subgroup.mem_zpowers_iff.mp (h_ofAdd_gen a)
      obtain вҹЁj, hjвҹ© := Subgroup.mem_zpowers_iff.mp (h_ofAdd_gen b)
      have h_gвӮҒ_pow : (gвӮҒ ^ i : H) = (a, 1) := by
        have : (gвӮҒ ^ i : H) = (gвӮҒ.1 ^ i, gвӮҒ.2 ^ i) := rfl
        rw [this]
        refine Prod.ext ?_ ?_
        В· show (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) ^ i = a
          exact hi
        В· show (1 : CyclicGroup p) ^ i = 1
          exact one_zpow i
      have h_gвӮӮ_pow : (gвӮӮ ^ j : H) = (1, b) := by
        have : (gвӮӮ ^ j : H) = (gвӮӮ.1 ^ j, gвӮӮ.2 ^ j) := rfl
        rw [this]
        refine Prod.ext ?_ ?_
        В· show (1 : CyclicGroup p) ^ j = 1
          exact one_zpow j
        В· show (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) ^ j = b
          exact hj
      have hab_eq : (a, b) = gвӮҒ ^ i * gвӮӮ ^ j := by
        rw [h_gвӮҒ_pow, h_gвӮӮ_pow, Prod.mk_mul_mk, mul_one, one_mul]
      rw [hab_eq]
      exact mul_mem
        (Subgroup.mem_sup_left (Subgroup.zpow_mem _ (Subgroup.mem_zpowers gвӮҒ) _))
        (Subgroup.mem_sup_right (Subgroup.zpow_mem _ (Subgroup.mem_zpowers gвӮӮ) _))
    let std_map : (Fin 2 вҶ’ ZMod p) вҶ’вӮ—[ZMod p] Additive H :=
      b_std.constr (ZMod p) ![gвӮҒ_add, gвӮӮ_add]
    have h_std_map_eвӮҖ : std_map (b_std 0) = gвӮҒ_add := by
      change b_std.constr (ZMod p) ![gвӮҒ_add, gвӮӮ_add] (b_std 0) = _
      rw [Module.Basis.constr_basis]; rfl
    have h_std_map_eвӮҒ : std_map (b_std 1) = gвӮӮ_add := by
      change b_std.constr (ZMod p) ![gвӮҒ_add, gвӮӮ_add] (b_std 1) = _
      rw [Module.Basis.constr_basis]; rfl
    have h_std_map_apply : вҲҖ (a b : ZMod p),
        std_map (![a, b] : Fin 2 вҶ’ ZMod p) = a вҖў gвӮҒ_add + b вҖў gвӮӮ_add := by
      intro a b
      have h_decomp :
          (![a, b] : Fin 2 вҶ’ ZMod p) =
          a вҖў (b_std 0 : Fin 2 вҶ’ ZMod p) + b вҖў (b_std 1 : Fin 2 вҶ’ ZMod p) := by
        ext i; fin_cases i <;> simp [b_std, Pi.basisFun_apply, Pi.single]
      rw [h_decomp, map_add, LinearMap.map_smul, LinearMap.map_smul,
          h_std_map_eвӮҖ, h_std_map_eвӮҒ]
    -- std_map is surjective using gвӮҒ, gвӮӮ generating
    have h_std_surj : LinearMap.range std_map = вҠӨ := by
      rw [eq_top_iff]
      intro h _
      have h_mem : Additive.toMul h вҲҲ Subgroup.zpowers gвӮҒ вҠ” Subgroup.zpowers gвӮӮ :=
        h_gen_g в–ё Subgroup.mem_top _
      rw [Subgroup.mem_sup] at h_mem
      obtain вҹЁx, hx_mem, y, hy_mem, hxyвҹ© := h_mem
      obtain вҹЁa, haвҹ© := Subgroup.mem_zpowers_iff.mp hx_mem
      obtain вҹЁb, hbвҹ© := Subgroup.mem_zpowers_iff.mp hy_mem
      have h_mul : Additive.toMul h = gвӮҒ ^ a * gвӮӮ ^ b := by rw [вҶҗ hxy, ha, hb]
      have h_add : h = (a : в„Ө) вҖў gвӮҒ_add + (b : в„Ө) вҖў gвӮӮ_add := by
        have hzpow_gвӮҒ : Additive.ofMul (gвӮҒ ^ a) = (a : в„Ө) вҖў gвӮҒ_add := ofMul_zpow a gвӮҒ
        have hzpow_gвӮӮ : Additive.ofMul (gвӮӮ ^ b) = (b : в„Ө) вҖў gвӮӮ_add := ofMul_zpow b gвӮӮ
        have h_id : Additive.ofMul (Additive.toMul h) = h := rfl
        rw [вҶҗ h_id, h_mul, ofMul_mul, hzpow_gвӮҒ, hzpow_gвӮӮ]
      refine вҹЁ![(a : ZMod p), (b : ZMod p)], ?_вҹ©
      rw [h_std_map_apply, h_add]
      rw [Int.cast_smul_eq_zsmul, Int.cast_smul_eq_zsmul]
    have h_std_inj : Function.Injective std_map :=
      (LinearMap.injective_iff_surjective_of_finrank_eq_finrank h_finrank_eq).mpr
        (LinearMap.range_eq_top.mp h_std_surj)
    let std_ПҶ : (Fin 2 вҶ’ ZMod p) вүғвӮ—[ZMod p] Additive H :=
      LinearEquiv.ofBijective std_map вҹЁh_std_inj, LinearMap.range_eq_top.mp h_std_surjвҹ©
    -- Now build ОІ_eq : Additive H вүғвӮ— Additive H sending gвӮҒ_add вҶҰ u_add, gвӮӮ_add вҶҰ v_add
    let ОІ_eq : Additive H вүғвӮ—[ZMod p] Additive H := std_ПҶ.symm.trans ПҶ
    -- ОІ_eq sends g_1_add вҶҰ u_add, g_2_add вҶҰ v_add
    have h_std_ПҶ_eвӮҖ : std_ПҶ (b_std 0) = gвӮҒ_add := by
      change std_map (b_std 0) = gвӮҒ_add; exact h_std_map_eвӮҖ
    have h_std_ПҶ_eвӮҒ : std_ПҶ (b_std 1) = gвӮӮ_add := by
      change std_map (b_std 1) = gвӮӮ_add; exact h_std_map_eвӮҒ
    have h_std_ПҶ_inv_gвӮҒ : std_ПҶ.symm gвӮҒ_add = b_std 0 := by
      rw [вҶҗ h_std_ПҶ_eвӮҖ]; exact std_ПҶ.symm_apply_apply (b_std 0)
    have h_std_ПҶ_inv_gвӮӮ : std_ПҶ.symm gвӮӮ_add = b_std 1 := by
      rw [вҶҗ h_std_ПҶ_eвӮҒ]; exact std_ПҶ.symm_apply_apply (b_std 1)
    have h_ОІ_eq_gвӮҒ : ОІ_eq gвӮҒ_add = u_add := by
      change ПҶ (std_ПҶ.symm gвӮҒ_add) = u_add
      rw [h_std_ПҶ_inv_gвӮҒ]
      change ПҶ_map (b_std 0) = u_add
      exact h_ПҶ_map_eвӮҖ
    have h_ОІ_eq_gвӮӮ : ОІ_eq gвӮӮ_add = v_add := by
      change ПҶ (std_ПҶ.symm gвӮӮ_add) = v_add
      rw [h_std_ПҶ_inv_gвӮӮ]
      change ПҶ_map (b_std 1) = v_add
      exact h_ПҶ_map_eвӮҒ
    -- Build ОІ : MulAut H
    let ОІ_add : Additive H вүғ+ Additive H := ОІ_eq.toAddEquiv
    let ОІ : MulAut H := AddAutAdditive (G := H) ОІ_add
    -- ОІ gвӮҒ = u, ОІ gвӮӮ = v
    have h_ОІ_gвӮҒ : ОІ gвӮҒ = u := by
      change ОІ.toMonoidHom gвӮҒ = u
      have h : ОІ_add gвӮҒ_add = u_add := h_ОІ_eq_gвӮҒ
      change Additive.toMul (ОІ_add (Additive.ofMul gвӮҒ)) = u
      rw [h]; rfl
    have h_ОІ_gвӮӮ : ОІ gвӮӮ = v := by
      change ОІ.toMonoidHom gвӮӮ = v
      have h : ОІ_add gвӮӮ_add = v_add := h_ОІ_eq_gвӮӮ
      change Additive.toMul (ОІ_add (Additive.ofMul gвӮӮ)) = v
      rw [h]; rfl
    -- Conclude: ОІ * cpcpInvSecond p * ОІвҒ»В№ = Пғ
    -- Use isConj_iff: IsConj a b вҶ” вҲғ c, c * a * cвҒ»В№ = b
    rw [isConj_iff]
    refine вҹЁОІ, ?_вҹ©
    -- Goal: ОІ * cpcpInvSecond p * ОІвҒ»В№ = Пғ
    -- Equivalent to ОІ * cpcpInvSecond p = Пғ * ОІ
    rw [mul_inv_eq_iff_eq_mul]
    show ОІ * cpcpInvSecond p = Пғ * ОІ
    -- Verify on generators gвӮҒ and gвӮӮ
    have h_at_gвӮҒ : (ОІ * cpcpInvSecond p) gвӮҒ = (Пғ * ОІ) gвӮҒ := by
      rw [MulAut.mul_apply, MulAut.mul_apply]
      show ОІ (cpcpInvSecond p gвӮҒ) = Пғ (ОІ gвӮҒ)
      have h_inv_gвӮҒ : cpcpInvSecond p gвӮҒ = gвӮҒ := by
        show ((gвӮҒ.1, gвӮҒ.2вҒ»В№) : H) = gвӮҒ
        change ((Multiplicative.ofAdd (1 : ZMod p), (1 : CyclicGroup p)вҒ»В№) : H) =
          (Multiplicative.ofAdd (1 : ZMod p), (1 : CyclicGroup p))
        rw [inv_one]
      rw [h_inv_gвӮҒ, h_ОІ_gвӮҒ, hu_fixed]
    have h_at_gвӮӮ : (ОІ * cpcpInvSecond p) gвӮӮ = (Пғ * ОІ) gвӮӮ := by
      rw [MulAut.mul_apply, MulAut.mul_apply]
      show ОІ (cpcpInvSecond p gвӮӮ) = Пғ (ОІ gвӮӮ)
      have h_inv_gвӮӮ : cpcpInvSecond p gвӮӮ = gвӮӮвҒ»В№ := by
        show ((gвӮӮ.1, gвӮӮ.2вҒ»В№) : H) = gвӮӮвҒ»В№
        change ((1 : CyclicGroup p), (Multiplicative.ofAdd (1 : ZMod p))вҒ»В№) =
          ((1 : CyclicGroup p)вҒ»В№, (Multiplicative.ofAdd (1 : ZMod p))вҒ»В№)
        rw [inv_one]
      rw [h_inv_gвӮӮ, map_inv, h_ОІ_gвӮӮ, hv_inv]
    -- Extract pointwise equalities from h_at_gвӮҒ, h_at_gвӮӮ
    have hОІПғ_gвӮҒ : ОІ (cpcpInvSecond p gвӮҒ) = Пғ (ОІ gвӮҒ) := by
      have := h_at_gвӮҒ
      rwa [MulAut.mul_apply, MulAut.mul_apply] at this
    have hОІПғ_gвӮӮ : ОІ (cpcpInvSecond p gвӮӮ) = Пғ (ОІ gвӮӮ) := by
      have := h_at_gвӮӮ
      rwa [MulAut.mul_apply, MulAut.mul_apply] at this
    -- Now show ОІ * cpcpInvSecond p = Пғ * ОІ by checking they agree on H
    -- It suffices to check on gвӮҒ and gвӮӮ since they generate H
    apply MulEquiv.ext
    intro x
    -- Express x = gвӮҒ^a * gвӮӮ^b
    have hx_mem : x вҲҲ Subgroup.zpowers gвӮҒ вҠ” Subgroup.zpowers gвӮӮ :=
      h_gen_g в–ё Subgroup.mem_top x
    rw [Subgroup.mem_sup] at hx_mem
    obtain вҹЁwвӮҒ, hwвӮҒ_mem, wвӮӮ, hwвӮӮ_mem, hw_eqвҹ© := hx_mem
    obtain вҹЁa, haвҹ© := Subgroup.mem_zpowers_iff.mp hwвӮҒ_mem
    obtain вҹЁb, hbвҹ© := Subgroup.mem_zpowers_iff.mp hwвӮӮ_mem
    have hx_eq : x = gвӮҒ ^ a * gвӮӮ ^ b := by rw [вҶҗ hw_eq, ha, hb]
    rw [hx_eq]
    show (ОІ * cpcpInvSecond p) (gвӮҒ ^ a * gвӮӮ ^ b) = (Пғ * ОІ) (gвӮҒ ^ a * gвӮӮ ^ b)
    rw [MulAut.mul_apply, MulAut.mul_apply]
    show ОІ (cpcpInvSecond p (gвӮҒ ^ a * gвӮӮ ^ b)) = Пғ (ОІ (gвӮҒ ^ a * gвӮӮ ^ b))
    rw [map_mul (cpcpInvSecond p), map_mul ОІ, map_mul ОІ, map_mul Пғ,
        map_zpow (cpcpInvSecond p), map_zpow (cpcpInvSecond p),
        map_zpow ОІ, map_zpow ОІ, map_zpow ОІ, map_zpow ОІ,
        map_zpow Пғ, map_zpow Пғ, hОІПғ_gвӮҒ, hОІПғ_gвӮӮ]

/-! ## Range cards for the new canonical actions. -/

/-- The order of `cpcpInvSecond p` is exactly 2 (provided p вү  2). -/
lemma orderOf_cpcpInvSecond {p : в„•} [hp : Fact p.Prime] (hp_ne_2 : p вү  2) :
    orderOf (cpcpInvSecond p) = 2 := by
  haveI : NeZero p := вҹЁhp.out.pos.ne'вҹ©
  refine orderOf_eq_prime (cpcpInvSecond_sq p) ?_
  intro h
  -- (cpcpInvSecond p) = 1 вҮ’ on the pair (1, ofAdd 1), second coord inverts to itself.
  have h_app := congr_fun (congr_arg DFunLike.coe h)
    ((1 : CyclicGroup p), (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p))
  have h_eq : ((1 : CyclicGroup p), (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№) =
      ((1 : CyclicGroup p), (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)) := h_app
  have h_inv : (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№ =
      (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) :=
    (Prod.mk.injEq _ _ _ _).mp h_eq |>.2
  -- This gives 1 = -1 in ZMod p, hence p вҲЈ 2, hence p = 2.
  have h_zmod_eq : (-1 : ZMod p) = (1 : ZMod p) := by
    have : (Multiplicative.ofAdd (-(1 : ZMod p)) : CyclicGroup p) =
        (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) := by
      rw [show (Multiplicative.ofAdd (-(1 : ZMod p)) : CyclicGroup p) =
        (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№ from rfl]
      exact h_inv
    exact (Multiplicative.ofAdd.injective this)
  -- (-1 : ZMod p) = 1 means 2 вүЎ 0 (mod p), hence p вҲЈ 2, hence p = 2.
  have h_two_zero : (2 : ZMod p) = 0 := by linear_combination -h_zmod_eq
  -- p вҲЈ 2 because (2 : ZMod p) = 0
  have h_two_cast : ((2 : в„•) : ZMod p) = 0 := by exact_mod_cast h_two_zero
  have h_p_dvd : p вҲЈ 2 := (ZMod.natCast_eq_zero_iff 2 p).mp h_two_cast
  have h_p_eq : p = 2 :=
    (Nat.prime_dvd_prime_iff_eq hp.out Nat.prime_two).mp h_p_dvd
  exact hp_ne_2 h_p_eq

/-- The order of `cpcpInvBoth p` is exactly 2 (provided p вү  2). -/
lemma orderOf_cpcpInvBoth {p : в„•} [hp : Fact p.Prime] (hp_ne_2 : p вү  2) :
    orderOf (cpcpInvBoth p) = 2 := by
  haveI : NeZero p := вҹЁhp.out.pos.ne'вҹ©
  refine orderOf_eq_prime (cpcpInvBoth_sq p) ?_
  intro h
  have h_app := congr_fun (congr_arg DFunLike.coe h)
    ((Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p), (1 : CyclicGroup p))
  have h_eq : ((Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№,
      (1 : CyclicGroup p)вҒ»В№) =
      ((Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p), (1 : CyclicGroup p)) := h_app
  have h_inv : (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№ =
      (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) :=
    (Prod.mk.injEq _ _ _ _).mp h_eq |>.1
  have h_zmod_eq : (-1 : ZMod p) = (1 : ZMod p) := by
    have : (Multiplicative.ofAdd (-(1 : ZMod p)) : CyclicGroup p) =
        (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p) := by
      rw [show (Multiplicative.ofAdd (-(1 : ZMod p)) : CyclicGroup p) =
        (Multiplicative.ofAdd (1 : ZMod p) : CyclicGroup p)вҒ»В№ from rfl]
      exact h_inv
    exact (Multiplicative.ofAdd.injective this)
  have h_two_zero : (2 : ZMod p) = 0 := by linear_combination -h_zmod_eq
  have h_two_cast : ((2 : в„•) : ZMod p) = 0 := by exact_mod_cast h_two_zero
  have h_p_dvd : p вҲЈ 2 := (ZMod.natCast_eq_zero_iff 2 p).mp h_two_cast
  exact hp_ne_2 ((Nat.prime_dvd_prime_iff_eq hp.out Nat.prime_two).mp h_p_dvd)

lemma canonicalC2OnCpCpAction_r1_range_card {p : в„•} [hp : Fact p.Prime] (hp_ne_2 : p вү  2) :
    Nat.card (canonicalC2OnCpCpAction_r1 p).range = 2 := by
  haveI : NeZero p := вҹЁhp.out.pos.ne'вҹ©
  show Nat.card (cyclicHom 2 (cpcpInvSecond p) (cpcpInvSecond_sq p)).range = 2
  rw [cyclicHom_range, Nat.card_zpowers, orderOf_cpcpInvSecond hp_ne_2]

lemma canonicalC2OnCpCpAction_r2_range_card {p : в„•} [hp : Fact p.Prime] (hp_ne_2 : p вү  2) :
    Nat.card (canonicalC2OnCpCpAction_r2 p).range = 2 := by
  haveI : NeZero p := вҹЁhp.out.pos.ne'вҹ©
  show Nat.card (cyclicHom 2 (cpcpInvBoth p) (cpcpInvBoth_sq p)).range = 2
  rw [cyclicHom_range, Nat.card_zpowers, orderOf_cpcpInvBoth hp_ne_2]

/-! ## Main classification of groups of order `2p^2`. -/

set_option maxHeartbeats 400000 in
theorem classification_2p2 {p : в„•} [h_p_prime : Fact p.Prime] [Group G]
    (h_ge_3 : p вүҘ 3) (h : Nat.card G = p ^ 2 * 2)
    : Nonempty (G вүғ* CyclicGroup (2 * p ^ 2))
      вҲЁ Nonempty (G вүғ* CyclicGroup p Г— CyclicGroup p Г— CyclicGroup 2)
      вҲЁ Nonempty (G вүғ* SemidirectProduct (CyclicGroup (p ^ 2)) (CyclicGroup 2)
                         (canonicalC2OnCp2Action (by omega : p вү  2)))
      вҲЁ Nonempty (G вүғ* SemidirectProduct (CyclicGroup p Г— CyclicGroup p) (CyclicGroup 2)
                         (canonicalC2OnCpCpAction_r1 p))
      вҲЁ Nonempty (G вүғ* SemidirectProduct (CyclicGroup p Г— CyclicGroup p) (CyclicGroup 2)
                         (canonicalC2OnCpCpAction_r2 p)) := by
  haveI : NeZero p := вҹЁh_p_prime.out.ne_zeroвҹ©
  haveI : Fact (Nat.Prime 2) := вҹЁby norm_numвҹ©
  have hp_ne_2 : p вү  2 := by omega
  haveI : Finite G := by
    apply Nat.finite_of_card_ne_zero; rw [h]
    have p_ne : p вү  0 := Nat.Prime.ne_zero h_p_prime.elim
    simp; tauto
  let n_p := Nat.card (Sylow p G)
  let n_2 := Nat.card (Sylow 2 G)
  have hpne2 : p вү  2 := hp_ne_2
  have n_p_or_n_2_one : n_p = 1 вҲЁ n_2 = 1 :=
    p2q_group_has_normal_sylow_subgroup G hpne2 h
  have h2cop : Nat.Coprime 2 p :=
    ((by norm_num : (2 : в„•).Prime).coprime_of_ne h_p_prime.out (by omega))
  have h_p2_p_card : Nat.card G = p ^ 2 * 2 ^ 1 := by simpa using h
  have h_2_p2_card : Nat.card G = 2 ^ 1 * p ^ 2 := by rw [h]; ring
  rcases n_p_or_n_2_one with h_np_1 | h_n2_1
  В· -- n_p = 1: Sylow p-subgroup N (order pВІ) is normal, complement K of order 2
    let N : Sylow p G := default
    haveI : Subsingleton (Sylow p G) := (Nat.card_eq_one_iff_unique.mp h_np_1).1
    have h_N_card : Nat.card вҶҘ(N : Subgroup G) = p ^ 2 :=
      sylow_card_eq hpne2 h_p2_p_card N
    have h_N_idx_2 : вҲҖ N : Sylow p G, (вҶ‘N : Subgroup G).index = 2 := fun N => by
      simpa using sylow_index_eq hpne2 h_p2_p_card N
    obtain вҹЁK, hKвҹ© := Subgroup.exists_right_complement'_of_coprime
      (N := (вҶ‘N : Subgroup G)) (by
      rw [h_N_card, h_N_idx_2]
      exact ((h_p_prime.out.coprime_of_ne (by norm_num : (2 : в„•).Prime) hpne2)).pow_left 2)
    have h_iso_g_n_k := SemidirectProduct.mulEquivSubgroup hK
    let ПҶ : вҶҘK вҶ’* MulAut вҶҘ(вҶ‘N : Subgroup G) :=
      (вҶ‘N : Subgroup G).normalizerMonoidHom.comp
        (Subgroup.inclusion (by simp [Subgroup.normalizer_eq_top]))
    have hK_card : Nat.card вҶҘK = 2 := by
      have h1 : Nat.card G = Nat.card вҶҘ(вҶ‘N : Subgroup G) * Nat.card вҶҘK := by
        have heq := Nat.card_congr h_iso_g_n_k.toEquiv
        rw [SemidirectProduct.card] at heq; exact heq.symm
      rw [h_N_card, h] at h1
      have hp_pos : 0 < p ^ 2 := pow_pos h_p_prime.out.pos 2
      exact (Nat.eq_of_mul_eq_mul_left hp_pos h1).symm
    have eK : вҶҘK вүғ* CyclicGroup 2 :=
      Classical.choice (prime_classification_of_group (n := 2) hK_card)
    have h2p2cop : Nat.Coprime 2 (p ^ 2) := h2cop.pow_right 2
    have hp2_2cop : Nat.Coprime (p ^ 2) 2 := h2p2cop.symm
    rcases (p_squared_classification (p := p) h_N_card) with h_N_Cp2 | h_N_CpCp
    В· -- N вү… C_{pВІ}: bridge ПҶ via eN, eK, dispatch via classify_Cqn_rtimes_Cpm
      let eN := h_N_Cp2.some
      let ПҶ_inter : CyclicGroup 2 вҶ’* MulAut (CyclicGroup (p ^ 2)) :=
        (MulAut.congr eN).toMonoidHom.comp (ПҶ.comp eK.symm.toMonoidHom)
      have h_congr : вҶҘ(вҶ‘N : Subgroup G) вӢҠ[ПҶ] вҶҘK вүғ*
          SemidirectProduct (CyclicGroup (p ^ 2)) (CyclicGroup 2) ПҶ_inter :=
        SemidirectProduct.congr' (ПҶвӮҒ := ПҶ) (fn := eN) (fg := eK)
      haveI : NeZero (p ^ 2) := вҹЁpow_ne_zero 2 h_p_prime.out.ne_zeroвҹ©
      haveI : NeZero ((2:в„•)^1) := вҹЁpow_ne_zero 1 (by norm_num)вҹ©
      have h2p : (2 : в„•) вү  p := by omega
      have h21 : ((2:в„•)^1 : в„•) = 2 := by norm_num
      have hp22 : (p^2 : в„•) = p^2 := rfl
      have h_pre_iso := SemidirectProduct.transportCpCqIso h21.symm hp22.symm ПҶ_inter
      obtain вҹЁвҹЁr, hr_ltвҹ©, вҹЁe_preвҹ©, _вҹ© := classify_Cqn_rtimes_Cpm (p := 2) (q := p) h2p hpne2 1 2
        Nat.one_pos (by norm_num)
        (transportCpCqHom h21.symm hp22.symm ПҶ_inter)
      have hr_le : r вүӨ min 1 ((p - 1).factorization 2) := Nat.lt_succ_iff.mp hr_lt
      let canonR := fun r (hr : r вүӨ min 1 ((p - 1).factorization 2)) =>
        canonicalAction 2 p 2 1 h2p hpne2 (by norm_num) r hr
      let e_back := fun r hr => SemidirectProduct.transportCpCqIso h21 hp22 (canonR r hr)
      let pre := h_iso_g_n_k.symm.trans (h_congr.trans (h_pre_iso.trans
        (e_pre.trans (e_back r hr_le))))
      have hr_le_1 : r вүӨ 1 := hr_le.trans (min_le_left _ _)
      interval_cases r
      В· -- r = 0: trivial action вҶ’ G вүғ* C_{2pВІ}
        have h_triv := eq_one_of_range_card_one (by
          show Nat.card (transportCpCqHom h21 hp22 (canonR 0 hr_le)).range = 1
          rw [transportCpCqHom_range_card]
          simpa using canonicalAction_range_card 2 p 2 1 0 h2p hpne2 (by norm_num) hr_le)
        have : G вүғ* CyclicGroup (2 * p ^ 2) := pre.trans
          ((SemidirectProduct.mulEquivOfTrivialAction h_triv).trans
            (MulEquiv.prodComm.trans (CyclicGroup.prodMulEquiv h2p2cop)))
        tauto
      В· -- r = 1: matches `canonicalC2OnCp2Action`.
        tauto
    В· -- N вү… C_p Г— C_p: by_cases on ПҶ_inter triviality
      let eN := h_N_CpCp.some
      let ПҶ_inter : CyclicGroup 2 вҶ’* MulAut (CyclicGroup p Г— CyclicGroup p) :=
        (MulAut.congr eN).toMonoidHom.comp (ПҶ.comp eK.symm.toMonoidHom)
      have h_congr : вҶҘ(вҶ‘N : Subgroup G) вӢҠ[ПҶ] вҶҘK вүғ*
          SemidirectProduct (CyclicGroup p Г— CyclicGroup p) (CyclicGroup 2) ПҶ_inter :=
        SemidirectProduct.congr' (ПҶвӮҒ := ПҶ) (fn := eN) (fg := eK)
      by_cases h_triv : ПҶ_inter = 1
      В· -- ПҶ_inter trivial вҶ’ G вүғ* (C_p Г— C_p) Г— C_2
        have : G вүғ* CyclicGroup p Г— CyclicGroup p Г— CyclicGroup 2 :=
          h_iso_g_n_k.symm.trans (h_congr.trans
            ((SemidirectProduct.mulEquivOfTrivialAction h_triv).trans
              MulEquiv.prodAssoc))
        tauto
      В· -- ПҶ_inter nontrivial: image has order 2 by Lagrange (|C_2| = 2 prime)
        -- so ПҶ_inter is determined by a single order-2 Пғ; conjugate to canonвӮҒ or canonвӮӮ.
        -- ПҶ_inter(generator) has order dividing 2; nontriviality forces it to be 2.
        have h_card_K2 : Nat.card (CyclicGroup 2) = 2 := card_cyclicGroup 2
        -- |ПҶ_inter.range| divides |C_2| = 2, and isn't 1.
        have h_range_dvd : Nat.card ПҶ_inter.range вҲЈ 2 := by
          have := Subgroup.card_range_dvd ПҶ_inter; rwa [h_card_K2] at this
        have h_range_ne_1 : Nat.card ПҶ_inter.range вү  1 :=
          fun h => h_triv (eq_one_of_range_card_one h)
        have h_range_card : Nat.card ПҶ_inter.range = 2 := by
          rcases (Nat.dvd_prime Nat.prime_two).mp h_range_dvd with h1 | h2
          В· exact absurd h1 h_range_ne_1
          В· exact h2
        -- the generator (Multiplicative.ofAdd 1 : CyclicGroup 2) maps to some Пғ
        let gвӮӮ : CyclicGroup 2 := Multiplicative.ofAdd (1 : ZMod 2)
        let Пғ : MulAut (CyclicGroup p Г— CyclicGroup p) := ПҶ_inter gвӮӮ
        have hg2_sq : gвӮӮ ^ 2 = 1 := by
          have h := pow_card_eq_one' (G := CyclicGroup 2) (x := gвӮӮ)
          rwa [card_cyclicGroup] at h
        have hПғ_sq : Пғ ^ 2 = 1 := by
          have := congr_arg ПҶ_inter hg2_sq
          rwa [map_pow, map_one] at this
        -- Пғ вү  1: otherwise ПҶ_inter would be trivial since gвӮӮ generates.
        have hgвӮӮ_gen : вҲҖ x : CyclicGroup 2, x вҲҲ Subgroup.zpowers gвӮӮ := by
          intro x
          refine Subgroup.mem_zpowers_iff.mpr вҹЁ((Multiplicative.toAdd x).val : в„Ө), ?_вҹ©
          show Multiplicative.ofAdd (1 : ZMod 2) ^ ((Multiplicative.toAdd x).val : в„Ө) = x
          rw [вҶҗ Multiplicative.ofAdd.apply_symm_apply x]
          show Multiplicative.ofAdd (1 : ZMod 2) ^ ((Multiplicative.toAdd x).val : в„Ө)
              = Multiplicative.ofAdd (Multiplicative.toAdd x)
          rw [вҶҗ ofAdd_zsmul, zsmul_one]
          congr 1
          push_cast
          exact ZMod.natCast_zmod_val _
        have hПғ_ne_one : Пғ вү  1 := by
          intro hПғ1
          apply h_triv
          have hext : вҲҖ x : CyclicGroup 2, ПҶ_inter x = 1 := by
            intro x
            obtain вҹЁn, hnвҹ© := Subgroup.mem_zpowers_iff.mp (hgвӮӮ_gen x)
            have : ПҶ_inter x = (ПҶ_inter gвӮӮ) ^ n := by rw [вҶҗ hn, map_zpow]
            rw [this, show ПҶ_inter gвӮӮ = Пғ from rfl, hПғ1, one_zpow]
          ext x : 1; rw [hext x]; rfl
        have hПғ_order : orderOf Пғ = 2 := orderOf_eq_prime hПғ_sq hПғ_ne_one
        -- Apply mulAut_cpcp_order_two_conj.
        -- Helper: cyclicHom evaluated at gвӮӮ gives the underlying element.
        have hval_gвӮӮ : ((Multiplicative.toAdd gвӮӮ).val : в„Ө) = 1 := by
          change ((1 : ZMod 2).val : в„Ө) = 1
          rw [ZMod.val_one_eq_one_mod]; norm_num
        have h_r1_gвӮӮ : canonicalC2OnCpCpAction_r1 p gвӮӮ = cpcpInvSecond p := by
          show (cyclicHom 2 (cpcpInvSecond p) (cpcpInvSecond_sq p)) gвӮӮ = cpcpInvSecond p
          rw [cyclicHom_apply_eq_zpow, hval_gвӮӮ]; exact zpow_one _
        have h_r2_gвӮӮ : canonicalC2OnCpCpAction_r2 p gвӮӮ = cpcpInvBoth p := by
          show (cyclicHom 2 (cpcpInvBoth p) (cpcpInvBoth_sq p)) gвӮӮ = cpcpInvBoth p
          rw [cyclicHom_apply_eq_zpow, hval_gвӮӮ]; exact zpow_one _
        rcases mulAut_cpcp_order_two_conj hp_ne_2 Пғ hПғ_order with h_conj1 | h_conj2
        В· -- Пғ is conjugate to cpcpInvSecond p, hence ПҶ_inter вү… canonicalC2OnCpCpAction_r1 p
          obtain вҹЁcu, hcuвҹ© := h_conj1
          -- hcu : SemiconjBy (вҶ‘cu) (cpcpInvSecond p) Пғ, i.e. вҶ‘cu * cpcpInvSecond p = Пғ * вҶ‘cu.
          let c : MulAut (CyclicGroup p Г— CyclicGroup p) := (cu : MulAut _)
          have hc_eq : Пғ = c * cpcpInvSecond p * cвҒ»В№ := by
            have h1 : c * cpcpInvSecond p = Пғ * c := hcu
            have h2 : c * cpcpInvSecond p * cвҒ»В№ = Пғ * c * cвҒ»В№ := by rw [h1]
            rw [h2, mul_inv_cancel_right]
          let conj_hom : CyclicGroup 2 вҶ’* MulAut (CyclicGroup p Г— CyclicGroup p) :=
            { toFun := fun x => c * canonicalC2OnCpCpAction_r1 p x * cвҒ»В№
              map_one' := by simp
              map_mul' := fun a b => by
                simp only [map_mul]; group }
          have h_eq_on_gвӮӮ : ПҶ_inter gвӮӮ = conj_hom gвӮӮ := by
            show Пғ = c * canonicalC2OnCpCpAction_r1 p gвӮӮ * cвҒ»В№
            rw [h_r1_gвӮӮ]; exact hc_eq
          have h_eq : ПҶ_inter = conj_hom :=
            monoidHom_eq_of_generator_eq hgвӮӮ_gen h_eq_on_gвӮӮ
          have h_action_eq : вҲҖ x : CyclicGroup 2,
              ПҶ_inter x = c * canonicalC2OnCpCpAction_r1 p x * cвҒ»В№ :=
            fun x => congr_fun (congr_arg DFunLike.coe h_eq) x
          obtain вҹЁe_isoвҹ© := semidirectProduct_iso_of_conjugate_action
            (f_1 := canonicalC2OnCpCpAction_r1 p)
            (f_2 := ПҶ_inter) c 1
            (fun x => by simpa using h_action_eq x)
          have : G вүғ* SemidirectProduct (CyclicGroup p Г— CyclicGroup p) (CyclicGroup 2)
                       (canonicalC2OnCpCpAction_r1 p) :=
            h_iso_g_n_k.symm.trans (h_congr.trans e_iso.symm)
          tauto
        В· -- Пғ is conjugate to cpcpInvBoth p, hence ПҶ_inter вү… canonicalC2OnCpCpAction_r2 p
          obtain вҹЁcu, hcuвҹ© := h_conj2
          let c : MulAut (CyclicGroup p Г— CyclicGroup p) := (cu : MulAut _)
          have hc_eq : Пғ = c * cpcpInvBoth p * cвҒ»В№ := by
            have h1 : c * cpcpInvBoth p = Пғ * c := hcu
            have h2 : c * cpcpInvBoth p * cвҒ»В№ = Пғ * c * cвҒ»В№ := by rw [h1]
            rw [h2, mul_inv_cancel_right]
          let conj_hom : CyclicGroup 2 вҶ’* MulAut (CyclicGroup p Г— CyclicGroup p) :=
            { toFun := fun x => c * canonicalC2OnCpCpAction_r2 p x * cвҒ»В№
              map_one' := by simp
              map_mul' := fun a b => by
                simp only [map_mul]; group }
          have h_eq_on_gвӮӮ : ПҶ_inter gвӮӮ = conj_hom gвӮӮ := by
            show Пғ = c * canonicalC2OnCpCpAction_r2 p gвӮӮ * cвҒ»В№
            rw [h_r2_gвӮӮ]; exact hc_eq
          have h_eq : ПҶ_inter = conj_hom :=
            monoidHom_eq_of_generator_eq hgвӮӮ_gen h_eq_on_gвӮӮ
          have h_action_eq : вҲҖ x : CyclicGroup 2,
              ПҶ_inter x = c * canonicalC2OnCpCpAction_r2 p x * cвҒ»В№ :=
            fun x => congr_fun (congr_arg DFunLike.coe h_eq) x
          obtain вҹЁe_isoвҹ© := semidirectProduct_iso_of_conjugate_action
            (f_1 := canonicalC2OnCpCpAction_r2 p)
            (f_2 := ПҶ_inter) c 1
            (fun x => by simpa using h_action_eq x)
          have : G вүғ* SemidirectProduct (CyclicGroup p Г— CyclicGroup p) (CyclicGroup 2)
                       (canonicalC2OnCpCpAction_r2 p) :=
            h_iso_g_n_k.symm.trans (h_congr.trans e_iso.symm)
          tauto
  В· -- n_2 = 1: Sylow 2-subgroup Q (order 2) is normal, complement K of order pВІ
    let Q : Sylow 2 G := default
    haveI : Subsingleton (Sylow 2 G) := (Nat.card_eq_one_iff_unique.mp h_n2_1).1
    have h_Q_card : Nat.card вҶҘ(Q : Subgroup G) = 2 := by
      simpa using sylow_card_eq (Ne.symm hpne2) h_2_p2_card Q
    have h_Q_idx_p2 : вҲҖ Q : Sylow 2 G, (вҶ‘Q : Subgroup G).index = p ^ 2 := fun Q => by
      simpa using sylow_index_eq (Ne.symm hpne2) h_2_p2_card Q
    obtain вҹЁK, hKвҹ© := Subgroup.exists_right_complement'_of_coprime
      (N := (вҶ‘Q : Subgroup G)) (by
      rw [h_Q_card, h_Q_idx_p2]
      exact ((by norm_num : (2 : в„•).Prime).coprime_of_ne h_p_prime.out
        (by omega : (2 : в„•) вү  p)).pow_right 2)
    have h_iso_g_q_k := SemidirectProduct.mulEquivSubgroup hK
    let ПҶ : вҶҘK вҶ’* MulAut вҶҘ(вҶ‘Q : Subgroup G) :=
      (вҶ‘Q : Subgroup G).normalizerMonoidHom.comp
        (Subgroup.inclusion (by simp [Subgroup.normalizer_eq_top]))
    have hK_card : Nat.card вҶҘK = p ^ 2 := by
      have h1 : Nat.card G = Nat.card вҶҘ(вҶ‘Q : Subgroup G) * Nat.card вҶҘK := by
        have heq := Nat.card_congr h_iso_g_q_k.toEquiv
        rw [SemidirectProduct.card] at heq; exact heq.symm
      rw [h_Q_card, h] at h1
      exact (Nat.eq_of_mul_eq_mul_right (by norm_num : 0 < 2) (by linarith))
    have eQ : вҶҘ(вҶ‘Q : Subgroup G) вүғ* CyclicGroup 2 :=
      Classical.choice (prime_classification_of_group (n := 2) h_Q_card)
    -- Aut(C_2) is trivial since |Aut(C_2)| = 1
    have h_aut_card : Nat.card (MulAut вҶҘ(вҶ‘Q : Subgroup G)) = 1 := by
      have h_iso_aut : MulAut вҶҘ(вҶ‘Q : Subgroup G) вүғ* MulAut (CyclicGroup 2) :=
        MulAut.congr eQ
      have h_aut_c2 : Nat.card (MulAut (CyclicGroup 2)) = 1 := by
        have := card_mulAut_cyclicGroup_prime (q := 2)
        simpa using this
      exact (Nat.card_congr h_iso_aut.toEquiv).trans h_aut_c2
    -- ПҶ trivial since codomain has cardinality 1
    have h_phi_triv : ПҶ = 1 := eq_one_of_coprime_card (by
      rw [hK_card, h_aut_card]; simp)
    have h_2p2cop : Nat.Coprime 2 (p ^ 2) := h2cop.pow_right 2
    have h_p22cop : Nat.Coprime (p ^ 2) 2 := h_2p2cop.symm
    rcases (p_squared_classification (p := p) hK_card) with h_K_Cp2 | h_K_CpCp
    В· -- K вү… C_{pВІ}: G вү… C_2 Г— C_{pВІ} вү… C_{2pВІ}
      let eK := h_K_Cp2.some
      have : G вүғ* CyclicGroup (2 * p ^ 2) := h_iso_g_q_k.symm.trans
        ((SemidirectProduct.mulEquivOfTrivialAction h_phi_triv).trans
          ((eQ.prodCongr eK).trans (CyclicGroup.prodMulEquiv h_2p2cop)))
      tauto
    В· -- K вү… C_p Г— C_p: G вү… C_2 Г— (C_p Г— C_p) вү… C_p Г— C_p Г— C_2
      let eK := h_K_CpCp.some
      have : G вүғ* CyclicGroup p Г— CyclicGroup p Г— CyclicGroup 2 := h_iso_g_q_k.symm.trans
        ((SemidirectProduct.mulEquivOfTrivialAction h_phi_triv).trans
          ((eQ.prodCongr eK).trans (MulEquiv.prodComm.trans MulEquiv.prodAssoc)))
      tauto
